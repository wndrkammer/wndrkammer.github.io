---
permalink: /feed.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
<title>표면아래</title>
<subtitle>산업 분석</subtitle>
<link href="{{ site.url }}/"/>
<link rel="self" href="{{ site.url }}/feed.xml"/>
<id>{{ site.url }}/</id>
{%- if collections.posts.length %}
<updated>{{ collections.posts[0].data.date | iso }}</updated>
{%- endif %}
{%- for post in collections.posts | limit(20) %}
<entry>
<title>{{ post.data.title }}</title>
<link href="{{ site.url }}{{ post.url }}"/>
<id>{{ site.url }}{{ post.url }}</id>
<updated>{{ post.data.date | iso }}</updated>
<summary>{{ post.data.excerpt }}</summary>
</entry>
{%- endfor %}
</feed>
