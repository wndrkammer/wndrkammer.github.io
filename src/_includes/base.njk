<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ headTitle or (title ~ " | 표면아래") }}</title>
  <meta name="description" content="{{ description or excerpt or site.description }}">
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">
  <meta name="robots" content="index,follow">
  <meta property="og:title" content="{{ headTitle or title }}">
  <meta property="og:description" content="{{ description or excerpt or site.description }}">
  <meta property="og:type" content="website">
  <meta property="og:locale" content="ko_KR">
  <meta property="og:site_name" content="표면아래">
  <meta name="theme-color" content="#e9eaec">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+KR:wght@400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="alternate" type="application/atom+xml" href="/feed.xml" title="표면아래">
  {% if site.adsenseClient %}
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client={{ site.adsenseClient }}" crossorigin="anonymous"></script>
  {% endif %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "{{ site.author }}",
    "jobTitle": "{{ site.authorTitle }}",
    "description": "표면 아래의 구조를 발굴하는 산업 분석을 씁니다."
  }
  </script>
</head>
<body>
  <a class="skip-link" href="#content">본문으로 건너뛰기</a>
  <header class="site-header">
    <div class="container header-inner">
      <a class="wordmark" href="/">표면아래<span class="sub">산업 분석</span></a>
      <nav class="nav" aria-label="주요 메뉴">
        <a href="/#index">분석</a>
        <a href="/#sectors">섹터</a>
        <a href="/#principles">원칙</a>
        <a href="/about/">소개</a>
      </nav>
    </div>
  </header>
  <main id="content">
    {{ content | safe }}
  </main>
  <footer class="site-footer">
    <div class="container footer-inner">
      <span class="footer-brand">표면아래</span>
      <div class="footer-links">
        <a href="/#index">분석</a>
        <a href="/about/">소개</a>
        <a href="mailto:{{ site.email }}">{{ site.email }}</a>
      </div>
      <p class="footer-copy">© 2026 남승화 · 경제산업부 기자</p>
    </div>
  </footer>
</body>
</html>
